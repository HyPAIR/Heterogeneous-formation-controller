<?xml version="1.0"?>
<launch>
  <arg name="mission"               default="formation_test.json"/>

  <node pkg="Heterogeneous-formation-controller" type="animation_complete" name="animation_complete" output="screen">   
    <param name="mission"                    value="$(find Heterogeneous-formation-controller)/test/$(arg mission)" />
  </node>
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find Heterogeneous-formation-controller)/config/test.rviz" />

<!-- Nodes End -->
</launch>
